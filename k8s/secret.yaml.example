# Este es un archivo de ejemplo. NO versionar el secret real.
# Copia este archivo como k8s/secret.yaml y reemplaza los valores.
# k8s/secret.yaml está en .gitignore para no versionar credenciales reales.
apiVersion: v1
kind: Secret
metadata:
  name: inventario-app-secret
type: Opaque
data:
  API_KEY: <base64-de-tu-api-key-aqui>
